{
  "compilerOptions": {
    "target": "ES2020",
    "module": "nodenext",
    "moduleDetection": "force",
    "moduleResolution": "nodenext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist"
  },
  "include": ["src"]
}
